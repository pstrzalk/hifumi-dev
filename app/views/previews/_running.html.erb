<div class="preview-pane__header">
  <a href="<%= project.preview_url %>" target="_blank" class="preview-pane__url">
    <%= project.preview_url %><span class="arrow">↗</span>
  </a>
  <div class="flex items-center" style="gap: 8px;">
    <span class="tag tag--running"><span class="tag-dot"></span>running</span>
    <%= button_to "Stop", project_preview_path(project),
          method: :delete, class: "btn btn--primary btn--sm" %>
  </div>
</div>
<iframe
  src="<%= project.preview_url %>"
  class="preview-frame"
  sandbox="allow-same-origin allow-scripts allow-forms"></iframe>
