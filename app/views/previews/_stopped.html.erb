<div class="preview-pane__header">
  <span class="eyebrow" style="margin: 0;">preview</span>
  <span class="tag tag--stopped">stopped</span>
</div>
<div class="preview-pane__body">
  <div class="preview-pane__empty">
    <p style="margin: 0;">No preview running.</p>
    <%= button_to "Start preview", project_preview_path(project),
          method: :post, class: "btn btn--accent" %>
  </div>
</div>
