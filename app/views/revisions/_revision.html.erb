<% modifier =
     case revision.status
     when "pending"    then "pend"
     when "generating" then "gen"
     when "completed"  then "ok"
     when "failed"     then "err"
     end %>
<div id="<%= dom_id(revision) %>" class="revision-row revision-row--<%= modifier %>">
  <div class="stripe"></div>
  <div class="id">R-<%= "%03d" % revision.position %></div>
  <div class="tag-cell">
    <% if revision.status == "generating" %>
      <span class="tag tag--gen"><span class="tag-dot"></span>generating</span>
    <% else %>
      <span class="tag tag--<%= modifier %>"><%= revision.status %></span>
    <% end %>
  </div>
  <div class="summary"><%= revision.summary %></div>
  <div class="sha">
    <% if revision.completed? && revision.git_sha.present? %>
      <%= revision.git_sha.first(7) %>
    <% else %>
      —
    <% end %>
  </div>
</div>
