<%= turbo_frame_tag "github_export_pane" do %>
  <div class="preview-pane__header">
    <span class="eyebrow" style="margin: 0;">github</span>
    <%= render "github_exports/state_tag", project: project %>
  </div>
  <div class="preview-pane__body" style="gap: 12px;">
    <% case project.export_state.to_sym %>
    <% when :not_exported %>
      <% if project.exportable? %>
        <%= render "github_exports/form", project: project %>
      <% else %>
        <p class="small" style="margin: 0; color: var(--fg-muted);">
          <% if project.user.github_connection&.connected? %>
            Complete the first build before exporting.
          <% else %>
            Connect GitHub on <%= link_to "your profile", edit_user_registration_path, data: { turbo_frame: "_top" } %> to export.
          <% end %>
        </p>
      <% end %>
    <% when :exporting %>
      <p style="margin: 0;">Exporting to GitHub…</p>
    <% when :exported %>
      <p style="margin: 0;">
        <a href="<%= project.github_repo_url %>" target="_blank" class="preview-pane__url">
          <%= project.github_repo_full_name %><span class="arrow">↗</span>
        </a>
      </p>
      <% if project.exportable? %>
        <%= button_to "Push latest changes", project_github_export_path(project),
              method: :post, class: "btn btn--outline btn--sm",
              data: { turbo_frame: "github_export_pane" } %>
      <% elsif !project.user.github_connection&.connected? %>
        <p class="small" style="margin: 0; color: var(--fg-muted);">
          <%= link_to "Reconnect GitHub", edit_user_registration_path, data: { turbo_frame: "_top" } %> to push further changes.
        </p>
      <% end %>
    <% when :failed %>
      <p style="margin: 0; color: var(--err-fg);">Export failed.</p>
      <% if project.export_error.present? %>
        <pre class="preview-pane__error"><%= project.export_error %></pre>
      <% end %>
      <% if project.exportable? %>
        <div class="flex" style="gap: 8px; align-items: flex-start;">
          <%= button_to "Retry", project_github_export_path(project),
                method: :post, class: "btn btn--accent btn--sm",
                data: { turbo_frame: "github_export_pane" } %>
          <% if project.github_repo_full_name.present? %>
            <%= button_to "Create a new repository", project_github_export_path(project),
                  method: :delete, class: "btn btn--outline btn--sm",
                  data: { turbo_frame: "github_export_pane",
                          turbo_confirm: "Disconnect from #{project.github_repo_full_name} on GitHub? The repo will stay on GitHub — you can keep, archive, or delete it manually. The next export will create a fresh repo." } %>
          <% end %>
        </div>
      <% elsif !project.user.github_connection&.connected? %>
        <p class="small" style="margin: 0; color: var(--fg-muted);">
          <%= link_to "Reconnect GitHub", edit_user_registration_path, data: { turbo_frame: "_top" } %> to retry.
        </p>
      <% end %>
    <% end %>
  </div>
<% end %>
