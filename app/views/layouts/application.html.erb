<!DOCTYPE html>
<html>
  <head>
    <% page_title       = content_for(:title).presence       || "hifumi.dev — build Rails apps from a chat prompt" %>
    <% page_description = content_for(:description).presence || "Describe the app. Hifumi plans revisions, drives an LLM through implement → verify → commit, and hands you a clean Rails repo. Bring your own OpenRouter key. No vendor lock-in." %>
    <% og_image_url     = "#{request.base_url}/og.png" %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="hifumi.dev">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= page_description %>">
    <link rel="canonical" href="<%= request.base_url %><%= request.path %>">

    <meta property="og:type"           content="website">
    <meta property="og:site_name"      content="hifumi.dev">
    <meta property="og:title"          content="<%= page_title %>">
    <meta property="og:description"    content="<%= page_description %>">
    <meta property="og:url"            content="<%= request.base_url %><%= request.path %>">
    <meta property="og:image"          content="<%= og_image_url %>">
    <meta property="og:image:width"    content="1200">
    <meta property="og:image:height"   content="630">
    <meta property="og:image:alt"      content="hifumi.dev — 一二三 (hi-fu-mi) wordmark">

    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image"       content="<%= og_image_url %>">
    <meta name="twitter:image:alt"   content="hifumi.dev — 一二三 (hi-fu-mi) wordmark">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app-shell">
    <nav class="app-nav" data-controller="mobile-nav">
      <div class="app-nav-inner">
        <%= link_to root_path, class: "app-nav-brand" do %><span class="kanji" aria-hidden="true">一二三</span>hifumi<span class="tld">.dev</span><% end %>

        <div class="app-nav-items">
          <% if user_signed_in? %>
            <%= link_to "Projects", projects_path, class: "app-nav-link#{' active' if controller_name == 'projects'}" %>
            <span class="app-nav-sep">·</span>
            <%= link_to "Account", edit_user_registration_path, class: "app-nav-link#{' active' if controller_name == 'registrations'}" %>
            <span class="app-nav-sep">·</span>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                form: { class: "inline" }, class: "app-nav-link" %>
            <span class="app-nav-sep">·</span>
            <%= render "shared/github_nav_link" %>
          <% else %>
            <%= link_to "Log in", new_user_session_path, class: "app-nav-link" %>
            <span class="app-nav-sep">·</span>
            <%= link_to "Sign up", new_user_registration_path, class: "btn btn--accent btn--sm" %>
            <span class="app-nav-sep">·</span>
            <%= render "shared/github_nav_link" %>
          <% end %>
        </div>

        <% unless user_signed_in? %>
          <%= link_to "Sign up", new_user_registration_path,
                      class: "btn btn--accent btn--sm app-nav-cta-mobile" %>
        <% end %>
        <button type="button"
                class="app-nav-toggle"
                data-mobile-nav-target="toggle"
                data-action="click->mobile-nav#open"
                aria-controls="app-nav-drawer"
                aria-expanded="false"
                aria-label="Menu">
          <span aria-hidden="true">≡</span>
        </button>
      </div>

      <div id="app-nav-drawer"
           class="app-nav-drawer"
           data-mobile-nav-target="drawer"
           data-action="keydown@document->mobile-nav#keydown click->mobile-nav#backdropClick"
           hidden>
        <div class="app-nav-drawer__panel" role="dialog" aria-modal="true" aria-label="Menu">
          <button type="button"
                  class="app-nav-drawer__close"
                  data-action="click->mobile-nav#close"
                  aria-label="Close menu">✕</button>
          <div class="app-nav-drawer__items">
            <% if user_signed_in? %>
              <%= link_to "Projects", projects_path, class: "app-nav-drawer__link" %>
              <%= link_to "Account", edit_user_registration_path, class: "app-nav-drawer__link" %>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                  form: { class: "inline" }, class: "app-nav-drawer__link" %>
            <% else %>
              <%= link_to "Log in", new_user_session_path, class: "app-nav-drawer__link" %>
            <% end %>
            <%= link_to "https://github.com/pstrzalk/hifumi-dev",
                class: "app-nav-drawer__link app-nav-drawer__link--icon",
                target: "_blank", rel: "noopener" do %>
              <svg viewBox="0 0 16 16" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              <span>GitHub</span>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="app-main">
      <% if notice %>
        <div class="notice-strip notice-strip--ok" style="max-width: 1600px; margin: 0 auto 16px;">
          <div class="notice-strip__stripe"></div>
          <div class="notice-strip__tag">notice</div>
          <div class="notice-strip__body"><%= notice %></div>
          <div></div>
        </div>
      <% end %>
      <% if alert %>
        <div class="notice-strip notice-strip--err" style="max-width: 1600px; margin: 0 auto 16px;">
          <div class="notice-strip__stripe"></div>
          <div class="notice-strip__tag">error</div>
          <div class="notice-strip__body"><%= alert %></div>
          <div></div>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "shared/footer" %>
    <%= render "shared/cookie_consent" %>
  </body>
</html>
