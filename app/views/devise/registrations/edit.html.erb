<section style="max-width: 1600px; margin: 0 auto;">
  <div class="flex items-baseline" style="gap: 12px; margin-bottom: 16px;">
    <div class="eyebrow">account · settings</div>
  </div>
  <h1 class="h-section" style="margin: 0 0 24px;">Account</h1>

  <div data-controller="tabs" data-tabs-active-value="profile">
    <nav class="tab-nav" role="tablist" aria-label="account sections" aria-orientation="horizontal">
      <% [
        [:profile,      "一", "profile"],
        [:integrations, "二", "integrations"],
        [:danger,       "三", "danger zone"]
      ].each do |name, glyph, label| %>
        <% active = (name == :profile) %>
        <button type="button"
                id="tab_<%= name %>"
                class="tab-button<%= " is-active" if active %>"
                role="tab"
                aria-selected="<%= active ? "true" : "false" %>"
                aria-controls="pane_<%= name %>"
                tabindex="<%= active ? "0" : "-1" %>"
                data-tabs-target="tab"
                data-tab-name="<%= name %>"
                data-action="click->tabs#switch keydown->tabs#keydown">
          <span class="tab-button__numeral kanji" aria-hidden="true"><%= glyph %></span>
          <span class="tab-button__label"><%= label %></span>
        </button>
      <% end %>
    </nav>

    <%# ── 一 profile ───────────────────────────────────────────── %>
    <div id="pane_profile" role="tabpanel" aria-labelledby="tab_profile" tabindex="0"
         data-tabs-target="pane" data-tab-name="profile">
      <div style="max-width: 1280px;">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
              html: { id: "edit_account_form", method: :put,
                      class: "flex flex-col", style: "gap: 16px; margin-top: 24px;" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div>
            <%= f.label :email, class: "field-label" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "field-input" %>
          </div>

          <%= f.fields_for :profile do |pf| %>
            <div>
              <%= pf.label :first_name, class: "field-label" %>
              <%= pf.text_field :first_name, class: "field-input" %>
            </div>
            <div>
              <%= pf.label :last_name, class: "field-label" %>
              <%= pf.text_field :last_name, class: "field-input" %>
            </div>
          <% end %>

          <hr class="section-rule" style="margin: 8px 0;">
          <div class="eyebrow">change password<% if @minimum_password_length %> (<%= @minimum_password_length %> characters minimum)<% end %></div>

          <div>
            <%= f.label :password, "New password", class: "field-label" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "field-input" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "field-label" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "field-input" %>
          </div>

          <hr class="section-rule" style="margin: 8px 0;">

          <div>
            <%= f.label :current_password, "Current password (only required when changing your email or password)", class: "field-label" %>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "field-input" %>
          </div>

          <div class="form-actions">
            <%= f.submit "Update account", class: "btn btn--primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── 二 integrations ──────────────────────────────────────── %>
    <div id="pane_integrations" role="tabpanel" aria-labelledby="tab_integrations" tabindex="0"
         data-tabs-target="pane" data-tab-name="integrations" style="display: none;">
      <div style="max-width: 1280px;">
        <div style="margin-top: 24px;">
          <div class="eyebrow">openrouter</div>
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
                namespace: "or",
                html: { id: "openrouter_key_form", method: :put,
                        class: "flex flex-col", style: "gap: 16px; margin: 8px 0 0;" }) do |f| %>
            <%= f.fields_for :profile do |pf| %>
              <div>
                <%= pf.label :openrouter_api_key, "OpenRouter API key", class: "field-label" %>
                <%= pf.password_field :openrouter_api_key, autocomplete: "off",
                      placeholder: "(unchanged — leave blank to keep current key)", class: "field-input" %>
                <p style="margin: 6px 0 0; font-size: 20px; color: var(--fg-muted);">
                  Rotate at
                  <a href="https://openrouter.ai/keys" target="_blank"
                     style="color: var(--accent); text-decoration: underline; text-underline-offset: 2px;">openrouter.ai/keys</a>.
                </p>
              </div>
            <% end %>
            <div class="form-actions">
              <%= f.submit "Update key", class: "btn btn--primary" %>
            </div>
          <% end %>
        </div>

        <hr class="section-rule" style="margin: 24px 0;">

        <div>
          <div class="eyebrow">github</div>
          <% if current_user.github_connection&.connected? %>
            <p style="margin: 8px 0 12px; font-size: 20px; color: var(--fg-muted);">
              Connected as
              <a href="<%= current_user.github_connection.github_url %>" target="_blank"
                 style="color: var(--accent); text-decoration: underline; text-underline-offset: 2px;">@<%= current_user.github_connection.github_username %></a>.
            </p>
            <%= button_to "Disconnect GitHub", github_connection_path, method: :delete,
                  data: { turbo_confirm: "Disconnect from GitHub? You'll need to reauthorize before exporting again." },
                  class: "btn btn--danger" %>
          <% else %>
            <%= button_to "Connect GitHub", user_github_omniauth_authorize_path, method: :post,
                  data: { turbo: false }, class: "btn btn--primary" %>
            <p style="margin: 8px 0 0; font-size: 20px; color: var(--fg-muted);">
              Required to export projects to your GitHub account. Grants access to your repositories (<code style="font-family: var(--hi-font-mono);">repo</code> scope).
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── 三 danger zone ───────────────────────────────────────── %>
    <div id="pane_danger" role="tabpanel" aria-labelledby="tab_danger" tabindex="0"
         data-tabs-target="pane" data-tab-name="danger" style="display: none;">
      <div style="max-width: 1280px;">
        <div style="margin-top: 24px;">
          <p style="margin: 0 0 12px; font-size: 20px; color: var(--fg-muted);">
            Deletes your account and all associated projects. This cannot be undone.
          </p>
          <%= button_to "Cancel my account", registration_path(resource_name), method: :delete,
                data: { turbo_confirm: "Are you sure?" }, class: "btn btn--danger" %>
        </div>
      </div>
    </div>
  </div>
</section>
