<section style="max-width: 1600px; margin: 0 auto;" data-controller="suggestions">
  <div class="flex items-baseline" style="gap: 12px; margin-bottom: 16px;">
    <div class="eyebrow">studio · <span class="mono">new project</span></div>
  </div>
  <h1 class="h-section" style="margin: 0 0 24px;">Describe the app you want to build</h1>

  <% if @error %>
    <div class="notice-strip notice-strip--err" style="max-width: 720px; margin-bottom: 16px;">
      <div class="notice-strip__stripe"></div>
      <div class="notice-strip__tag">error</div>
      <div class="notice-strip__body"><%= @error %></div>
      <div></div>
    </div>
  <% end %>

  <nav class="tab-nav" aria-label="current step" style="border-bottom: 1px solid var(--rule);">
    <div class="tab-button is-active" aria-current="step" style="flex: 0 0 33.3333%; cursor: default;">
      <span class="tab-button__numeral kanji" aria-hidden="true">一</span>
      <span class="tab-button__label">new</span>
    </div>
  </nav>

  <%= form_with model: @project, url: projects_path do |f| %>
    <div class="form-grid">
      <div>
        <label class="field-label" for="project_description">Project description</label>
        <%= f.text_area :description,
            rows: 8,
            id: "project_description",
            placeholder: "a yoga studio site. Class schedule, online booking, member accounts with class packs, instructor logins, an admin panel, and a calm minimal theme",
            class: "field-textarea",
            data: { suggestions_target: "textarea" } %>
        <div style="margin-top: 24px;">
          <%= f.submit "Start building", class: "btn btn--accent", style: "font-size: 24px; padding: 12px 28px;" %>
        </div>
      </div>

      <div>
        <div class="eyebrow" style="margin-bottom: 8px;">or pick a starting point</div>
        <div class="suggestion-grid suggestion-grid--column">
          <% [
            "Flower shop with checkout",
            "Todo list with Tailwind",
            "Team standup tracker",
            "Blog with posts and comments",
            "Bookmark manager with accounts and admin panel",
            "Habit tracker with streaks and cyberpunk theme",
            "Event RSVP page with host login and minimalist look",
            "Reading list with notes and magazine-style layout",
          ].each do |suggestion| %>
            <button type="button"
                    class="suggestion-card"
                    data-action="click->suggestions#prefill"
                    data-suggestions-value-param="<%= suggestion %>">
              <span class="suggestion-card__stripe" aria-hidden="true"></span>
              <span class="suggestion-card__body"><%= suggestion %></span>
            </button>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</section>
