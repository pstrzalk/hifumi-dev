#!/usr/bin/env sh
# Wrapper: roast via local `claude -p` (Claude Code subscription).
# No ANTHROPIC_API_KEY / OPENROUTER — Claude CLI uses OAuth from `claude login`.
# For OpenRouter mode (paid): bin/roast-openrouter

set -e

# Clear any overrides from the shell env so the claude CLI uses the subscription.
unset ANTHROPIC_API_KEY
unset ANTHROPIC_AUTH_TOKEN
unset ANTHROPIC_BASE_URL
unset ANTHROPIC_DEFAULT_OPUS_MODEL
unset ANTHROPIC_DEFAULT_SONNET_MODEL
unset ANTHROPIC_DEFAULT_HAIKU_MODEL

cd "$(dirname "$0")/.."

# Pin Ruby to 4.0.2 (see .ruby-version). When the wrapper is invoked as a subprocess
# from a shell under a different Ruby (e.g. the default 3.2.6), the frum shim for bundle
# resolves the wrong version and looks for gems in 3.2.0 instead of 4.0.0.
RUBY_VERSION_PIN=$(cat .ruby-version)
FRUM_RUBY_BIN="$HOME/.frum/versions/$RUBY_VERSION_PIN/bin"
if [ -d "$FRUM_RUBY_BIN" ]; then
  export PATH="$FRUM_RUBY_BIN:$PATH"
fi

exec bundle exec roast "$@"
